{
  "manifest_version": 3,
  "name": "MemWyre",
  "version": "1.0",
  "description": "Connect your second brain to your browser. Capture content and inject memory into any AI.",
  "permissions": [
    "activeTab",
    "storage",
    "sidePanel",
    "contextMenus"
  ],
  "host_permissions": [
    "https://server.memwyre.tech/*",
    "https://memwyre.tech/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open MemWyre",
    "default_icon": "logo.png"
  },
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.youtube.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*"
      ],
      "js": [
        "config.js",
        "content.js"
      ]
    },
    {
      "matches": [
        "https://server.memwyre.tech/*",
        "https://memwyre.tech/*"
      ],
      "js": [
        "config.js",
        "auth_relay.js"
      ],
      "run_at": "document_start"
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://server.memwyre.tech/*",
      "https://memwyre.tech/*"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "logo.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
